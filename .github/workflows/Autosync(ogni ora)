name: Sync con Upstream

permissions:
  contents: write

on:
  schedule:
    - cron: '0 * * * *' # Ogni ora, al minuto zero
  workflow_dispatch: # Ti permette di farlo partire a mano per testare

jobs:
  sync:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Sync Upstream
        env:
          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        run: |
          gh repo sync 4kki94/miodbrating --source realbestia1/erdb --force
